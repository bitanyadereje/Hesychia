---
import Layout from '../layouts/Layout.astro';
import ChatWidget from '../components/ChatWidget';
---

<Layout title="Eikon — St. Isaac the Syrian">
  <main class="min-h-screen flex items-center justify-center p-4 md:p-8">
    <div class="w-full max-w-3xl">

      <!-- Icon-arch header -->
      <div class="text-center mb-10">
        <svg
          class="mx-auto mb-2"
          width="120"
          height="36"
          viewBox="0 0 120 36"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path d="M60 2 L60 12 M53 8 L67 8" stroke="#a97f2e" stroke-width="1.4" stroke-linecap="round" />
          <path d="M8 30 Q60 -6 112 30" stroke="#a97f2e" stroke-width="1.1" fill="none" opacity="0.75" />
        </svg>

        <h1 class="text-5xl md:text-6xl font-display font-semibold text-ink">
          Eikon
        </h1>
        <p class="text-lg md:text-xl italic font-serif text-ink-soft mt-3">
          A window into the wisdom of St. Isaac the Syrian
        </p>

        <div class="flex items-center justify-center gap-3 mt-5">
          <span class="h-px w-16 bg-gradient-to-r from-transparent to-gold"></span>
          <span class="text-porphyry text-sm leading-none">✝</span>
          <span class="h-px w-16 bg-gradient-to-l from-transparent to-gold"></span>
        </div>
      </div>

      <!-- Chat Widget -->
      <div class="relative bg-vellum-card rounded-sm shadow-[0_6px_28px_rgba(42,29,20,0.16)] border border-gold/30 p-4 md:p-7">
        <!-- corner fleurons -->
        <svg class="absolute -top-2 -left-2 w-5 h-5 opacity-60" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M2 18 C2 9 9 2 18 2" stroke="#a97f2e" stroke-width="1.25" />
          <circle cx="2" cy="18" r="1.4" fill="#a97f2e" />
        </svg>
        <svg class="absolute -top-2 -right-2 w-5 h-5 opacity-60 -scale-x-100" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M2 18 C2 9 9 2 18 2" stroke="#a97f2e" stroke-width="1.25" />
          <circle cx="2" cy="18" r="1.4" fill="#a97f2e" />
        </svg>
        <svg class="absolute -bottom-2 -left-2 w-5 h-5 opacity-60 -scale-y-100" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M2 18 C2 9 9 2 18 2" stroke="#a97f2e" stroke-width="1.25" />
          <circle cx="2" cy="18" r="1.4" fill="#a97f2e" />
        </svg>
        <svg class="absolute -bottom-2 -right-2 w-5 h-5 opacity-60 scale-[-1]" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M2 18 C2 9 9 2 18 2" stroke="#a97f2e" stroke-width="1.25" />
          <circle cx="2" cy="18" r="1.4" fill="#a97f2e" />
        </svg>

        <ChatWidget client:load />
      </div>

      <!-- Footer -->
      <div class="text-center mt-8 text-sm text-ink-soft/70 font-serif">
        <p>Rooted in the Ascetical Homilies of St. Isaac of Nineveh</p>
        <p class="text-xs mt-1 tracking-widest uppercase font-display">Ancient wisdom for modern souls</p>
      </div>
    </div>
  </main>
</Layout>
