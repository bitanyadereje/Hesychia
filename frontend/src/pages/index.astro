---
import Layout from '../layouts/Layout.astro';
import ChatWidget from '../components/ChatWidget';
---

<Layout title="Hesychia — St. Isaac the Syrian">
  <!-- Orthodox Cross Watermark -->
  <div class="cross-watermark" aria-hidden="true">☦</div>

  <!-- Floating Particles -->
  <div class="particle" aria-hidden="true"></div>
  <div class="particle" aria-hidden="true"></div>
  <div class="particle" aria-hidden="true"></div>
  <div class="particle" aria-hidden="true"></div>
  <div class="particle" aria-hidden="true"></div>
  <div class="particle" aria-hidden="true"></div>
  <div class="particle" aria-hidden="true"></div>
  <div class="particle" aria-hidden="true"></div>

  <main class="min-h-screen flex items-center justify-center p-4 relative z-10">
    <div class="w-full max-w-4xl">
      <!-- Header -->
      <div class="text-center mb-8">
        <h1 class="logo">Hesychia</h1>
        <p class="text-xl md:text-2xl font-serif italic text-glow/70 mt-2">
          A window into the wisdom of St. Isaac the Syrian
        </p>
        <div class="ornamental-divider">
          <span class="text-gold/50">✦</span>
          <span class="text-gold/30">✦ ✦</span>
          <span class="text-gold/20">✦ ✦ ✦</span>
        </div>
      </div>

      <!-- Chat Widget -->
      <div class="parchment-card">
        <ChatWidget client:load />
      </div>

      <!-- Footer -->
      <div class="text-center mt-6 text-sm text-glow/30 font-serif">
        <p>Rooted in the Ascetical Homilies of St. Isaac the Syrian </p>
        <p class="text-xs mt-1">Hesychia — Silence that speaks</p>
      </div>
    </div>
  </main>

  <!-- Candle Glows -->
  <div class="candle-left" aria-hidden="true"></div>
  <div class="candle-right" aria-hidden="true"></div>
</Layout>